name: '抓包测试'
desc: '测试-描述'
rules:
  - DOMAIN-SUFFIX,baidu.com,🚧Proxy
http:
  mitm:
    - '*.elog.com'
  force-http-engine:
    - '*.elog.com'
  script:
    - match: ^https?://.*
      name: http-capture-all
      type: response
      require-body: true
      timeout: 10
      argument: ''
      binary-mode: false
      max-size: 2097152
      debug: false
